menu "Security Camera Configuration"

    menu "Device Identity"
        config BOARD_TYPE
            string "Board type identifier"
            default "esp32cam"
            help
                Short board name baked into the device ID. Examples:
                "esp32cam", "esp32s3-freenove", "esp32cam-pir".

                The full device ID assembled at boot is:
                    <board>-<mac6>-<fwver>
                e.g. "esp32cam-a1b2c3-0.2.0", where mac6 is the last
                3 bytes of the factory eFuse MAC and fwver comes from
                PROJECT_VER in CMakeLists.txt.
    endmenu

    menu "WiFi"
        config WIFI_SSID
            string "WiFi SSID"
            default "myssid"
            help
                SSID of the WiFi network to connect to.

        config WIFI_PASSWORD
            string "WiFi Password"
            default "mypassword"
            help
                Password for the WiFi network.

        config WIFI_MAX_RETRIES
            int "Maximum connection retries"
            default 5
            range 1 20
    endmenu

    menu "HTTP Endpoint"
        config HTTP_ENDPOINT_URL
            string "Remote HTTP endpoint base URL"
            default "http://192.168.1.100:8080/upload"
            help
                Base URL for the server upload endpoint. The camera ID is
                appended automatically: <url>/<camera_id>.

        config HTTP_TIMEOUT_MS
            int "HTTP request timeout (ms)"
            default 10000
            range 1000 60000

        config HTTP_BASIC_AUTH_ENABLE
            bool "Enable HTTP Basic Authentication"
            default y

        config HTTP_BASIC_AUTH_USERNAME
            string "Username"
            default "camera"
            depends on HTTP_BASIC_AUTH_ENABLE

        config HTTP_BASIC_AUTH_PASSWORD
            string "Password"
            default "changeme"
            depends on HTTP_BASIC_AUTH_ENABLE
    endmenu

    menu "OTA Updates"
        config OTA_ENABLE
            bool "Enable OTA firmware updates on boot"
            default y

        config OTA_FIRMWARE_URL
            string "Firmware base URL"
            default "changeme"
            depends on OTA_ENABLE
            help
                Base URL of the firmware directory. The device tries to GET:
                  <url>/<board>_v<N+1>.bin
                where N is the running version (integer). If 200 → update.
                If 404 → up to date. Server just hosts all versioned binaries.

                Board type is set under Device Identity → Board type identifier.

        config OTA_BASIC_AUTH_ENABLE
            bool "Enable HTTP Basic Authentication for OTA endpoints"
            default y
            depends on OTA_ENABLE

        config OTA_BASIC_AUTH_USERNAME
            string "Username"
            default "camera"
            depends on OTA_BASIC_AUTH_ENABLE

        config OTA_BASIC_AUTH_PASSWORD
            string "Password"
            default "camera"
            depends on OTA_BASIC_AUTH_ENABLE
    endmenu

    menu "Capture"
        config JPEG_QUALITY
            int "JPEG quality (lower = better, higher compression)"
            default 10
            range 4 63

        config FRAME_SIZE
            int "Frame size (framesize_t enum value)"
            default 9
            range 0 13
            help
                Camera capture resolution as framesize_t index.
                0=96x96, 1=QQVGA 160x120, 5=QVGA 320x240,
                8=VGA 640x480, 9=SVGA 800x600 (default),
                10=XGA 1024x768, 12=SXGA 1280x1024, 13=UXGA 1600x1200
    endmenu

    menu "Camera Pins (per-board values live in sdkconfig.defaults.<board>)"
        config CAM_PIN_PWDN
            int "PWDN pin (-1 if unused)"
            default 32

        config CAM_PIN_RESET
            int "RESET pin (-1 if unused)"
            default -1

        config CAM_PIN_XCLK
            int "XCLK pin"
            default 0

        config CAM_PIN_SIOD
            int "SIOD (SDA) pin"
            default 26

        config CAM_PIN_SIOC
            int "SIOC (SCL) pin"
            default 27

        config CAM_PIN_D7
            int "D7 pin"
            default 35

        config CAM_PIN_D6
            int "D6 pin"
            default 34

        config CAM_PIN_D5
            int "D5 pin"
            default 39

        config CAM_PIN_D4
            int "D4 pin"
            default 36

        config CAM_PIN_D3
            int "D3 pin"
            default 21

        config CAM_PIN_D2
            int "D2 pin"
            default 19

        config CAM_PIN_D1
            int "D1 pin"
            default 18

        config CAM_PIN_D0
            int "D0 pin"
            default 5

        config CAM_PIN_VSYNC
            int "VSYNC pin"
            default 25

        config CAM_PIN_HREF
            int "HREF pin"
            default 23

        config CAM_PIN_PCLK
            int "PCLK pin"
            default 22
    endmenu

endmenu
