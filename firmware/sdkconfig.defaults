# Shared settings for all boards. Board-specific config (target, flash,
# PSRAM, camera pins, partition table) lives in sdkconfig.defaults.<board>.
# Build with: idf.py @boards/<board>.args build

# Max CPU clock
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# Increase main task stack for HTTP + camera ops
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# HTTP client + TLS
CONFIG_ESP_HTTP_CLIENT_ENABLE_HTTPS=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
# Allocate TLS I/O buffers on demand and size them to the actual records
# instead of a fixed 16 KB each — keeps HTTPS affordable on the RAM-tight
# original ESP32. Deliberately NOT freeing the CA/config data after the
# handshake (MBEDTLS_DYNAMIC_FREE_CONFIG_DATA): the upload stream reconnects
# on failure, and freeing would require re-registering the cert each time.
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y

# WiFi
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=4
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=8

# TCP buffers sized so a whole JPEG frame (~30-45 KB) fits in the send buffer;
# with the 5760 B default a frame needs ~7 window round-trips over the WAN path
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=65534
CONFIG_LWIP_TCP_WND_DEFAULT=32768
CONFIG_LWIP_TCP_RECVMBOX_SIZE=32

# Custom partition table (per-board CSV set in sdkconfig.defaults.<board>)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_OFFSET=0x8000
