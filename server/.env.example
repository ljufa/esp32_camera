# Traefik reverse-proxy auth (htpasswd format, $ must be doubled to $$)
# Generate with:
#   echo $(htpasswd -nb camera_ui put_your_password_here) | sed -e s/\\$/\\$\\$/g
TRAEFIK_BASIC_AUTH_USERS=camera_stream:$$apr1$$XXXX$$...
TRAEFIK_UI_BASIC_AUTH_USERS=camera_ui:$$apr1$$XXXX$$...
TRAEFIK_HOST=your.domain.example.com

# Telegram bot — optional; omit both vars to disable notifications
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
